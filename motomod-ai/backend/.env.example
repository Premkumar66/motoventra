# ==============================================================
# MotoMod AI Backend — Environment Configuration Template
# Copy to .env and fill in real values
# ==============================================================

# ─── Application ─────────────────────────────────────────────
APP_NAME="MotoMod AI"
APP_VERSION="1.0.0"
APP_ENV="development"           # development | staging | production
DEBUG=true
SECRET_KEY="CHANGE_ME_USE_OPENSSL_RAND_HEX_32"
ALLOWED_HOSTS=["localhost","127.0.0.1","0.0.0.0"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# ─── API ─────────────────────────────────────────────────────
API_V1_PREFIX="/api/v1"
DOCS_URL="/docs"
REDOC_URL="/redoc"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY="CHANGE_ME_USE_OPENSSL_RAND_HEX_64"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=motomod_ai
POSTGRES_USER=motomod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://motomod:CHANGE_ME_STRONG_PASSWORD@localhost:5432/motomod_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
CACHE_TTL_BIKE_SECONDS=3600

# ─── MinIO (S3-compatible) ────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=motomod_admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_SECURE=false
MINIO_BUCKET_BIKES=motomod-bikes
MINIO_BUCKET_MODS=motomod-modifications
MINIO_BUCKET_USERS=motomod-users
MINIO_BUCKET_BUILDS=motomod-builds
MINIO_BUCKET_ML=motomod-ml-models
MINIO_BUCKET_DATASETS=motomod-datasets

# ─── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=Asia/Kolkata

# ─── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=motomod_ai
ML_MODELS_DIR=./ml/models/trained
ML_INFERENCE_BATCH_SIZE=32

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME_RAZORPAY_KEY
RAZORPAY_KEY_SECRET=CHANGE_ME_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
RAZORPAY_CURRENCY=INR

# ─── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM_EMAIL=noreply@motomod.ai
SMTP_FROM_NAME="MotoMod AI"

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=20

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# ─── Monitoring ──────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ─── ETL ─────────────────────────────────────────────────────
ETL_SCHEDULE_CRON="0 2 * * *"  # Run at 2 AM daily
ETL_MAX_FILE_SIZE_MB=500
ETL_SUPPORTED_FORMATS=["csv","xlsx","xls","json"]

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@motomod.ai
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_NAME="MotoMod Admin"
